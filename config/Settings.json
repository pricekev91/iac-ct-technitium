{
  "Application": {
    "AutoStartService": true,
    "BlockPeriod": [],
    "UpdateChannel": "stable"
  },
  "DNS": {
    "EnableEDNS": true,
    "EnableIPv6": false,
    "Recursion": true,
    "RecursionPolicy": "Allow"
  },
  "DnsOverTls": {
    "Enabled": false,
    "CertificatePath": "/etc/dns/tls/dns.crt",
    "PrivateKeyPath": "/etc/dns/tls/dns.key"
  },
  "DnsOverHttps": {
    "Enabled": false,
    "CertificatePath": "/etc/dns/tls/dns.crt",
    "PrivateKeyPath": "/etc/dns/tls/dns.key"
  },
  "NTP": {
    "Enabled": true,
    "Servers": [
      "0.pool.ntp.org",
      "1.pool.ntp.org",
      "2.pool.ntp.org"
    ]
  },
  "Log": {
    "LogLevel": "Info",
    "MaxFiles": 7,
    "MaxSize": 10
  }
}